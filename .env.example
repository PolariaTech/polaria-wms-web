# URL del backend (polaria-wms-api).
# Producción (Render):
NEXT_PUBLIC_API_BASE_URL=https://polaria-wms-api.onrender.com

# Desarrollo local: descomenta la línea de abajo y comenta la de Render.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# URL del chatbot Mateo IA (SSO handoff).
NEXT_PUBLIC_MATEO_URL=https://chatbot-mateo.vercel.app

# Widget Mateo embebido (chat flotante en el shell autenticado).
# Dev local: copiar IIFE de Widget-react → public/assets/mateo-widget.js
#   cd ../Widget-react && npm run build:lib
#   copy dist/assets/mateo-widget.js ../polaria-wms-web/public/assets/
NEXT_PUBLIC_MATEO_WIDGET_SCRIPT_URL=/assets/mateo-widget.js
# Producción (CDN Vercel del Widget-react, cuando exista el asset):
# NEXT_PUBLIC_MATEO_WIDGET_SCRIPT_URL=https://widget-react-rho.vercel.app/assets/mateo-widget.js
# Opcional: webhook n8n que el widget usa en runtime.
# NEXT_PUBLIC_MATEO_N8N_WEBHOOK_URL=https://n8n.polaria.tech/webhook/mateo-widget

# Supabase (lecturas directas con RLS desde el navegador).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Solo servidor: persiste alertas de demora en historial (route /api/operaciones/sync-demora-alertas).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Integración n8n — pedido a proveedor (solo servidor; no usar NEXT_PUBLIC_).
# Route handler: POST /api/pedido-proveedor (no se proxya a Nest; ver next.config.ts).
# URL del webhook de producción n8n (POST JSON con payload enriquecido).
PEDIDO_PROVEEDOR_WEBHOOK_URL=https://n8n.polaria.tech/webhook/polaria-wms-pedido-proveedor
# ID de plantilla/documento que consume el flujo n8n (campo documentId del payload).
PEDIDO_PROVEEDOR_DOCUMENT_ID=polaria-oc-proveedor-v1

# Integración n8n — solicitud de compra (solo servidor; no usar NEXT_PUBLIC_).
# Route handler: POST /api/solicitud-compra (no se proxya a Nest; ver next.config.ts).
# Se dispara automáticamente al crear una solicitud desde la app.
SOLICITUD_COMPRA_WEBHOOK_URL=https://polariatech.app.n8n.cloud/webhook-test/solicitudcompra

# Cloudinary — evidencias de entrega (foto + firma). Solo servidor.
# Route handler: POST /api/evidencia-transporte (no se proxya a Nest).
# Copiá las mismas variables de bodega-de-frio (.env).
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_EVIDENCIA_FOLDER=bodega-venta-evidencias
